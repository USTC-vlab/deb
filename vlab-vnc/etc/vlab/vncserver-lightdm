#!/bin/bash
# Need Bash for $PPID

DISPLAY=":0"
LIGHTDM_PID=$PPID
XVNC_PID=0
UBUNTU_VERSION=$(cut -f2 <<< "$(lsb_release -r)")

kill_vnc() {
  kill -s SIGTERM $XVNC_PID
  wait
}

if [ $# -gt 0 ]; then
  DISPLAY="$1"
fi

AUTHORITY="/var/run/lightdm/root/$DISPLAY"
LISTEN_ADDR="$(ip -j route get 172.31.0.2 | jq -r '.[0].prefsrc')"

if [ "$UBUNTU_VERSION" == "18.04" ]; then
  Xvnc "$DISPLAY" -interface "$LISTEN_ADDR" -rfbport 5900 -seat seat0 -SecurityTypes None -auth "$AUTHORITY" &
else
  Xvnc "$DISPLAY" -interface "$LISTEN_ADDR" -rfbport 5900 -seat seat0 -SecurityTypes None -auth "$AUTHORITY" -SendPrimary=0 &
fi

XVNC_PID=$!
trap kill_vnc SIGTERM

sleep 2
kill -s SIGUSR1 $LIGHTDM_PID

wait
exit 0
